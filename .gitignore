# ===================
# OS & IDE
# ===================
.DS_Store
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# ===================
# Backend (Java/Maven)
# ===================
tesla-miniapp-backend/target/
tesla-miniapp-backend/*.log
tesla-miniapp-backend/logs/

# Sensitive config - use application.yml.example as template
tesla-miniapp-backend/src/main/resources/application.yml
tesla-miniapp-backend/src/main/resources/application-*.yml
!tesla-miniapp-backend/src/main/resources/application.yml.example

# ===================
# Frontend (Node/Vue)
# ===================
tesla-miniapp-frontend/node_modules/
tesla-miniapp-frontend/dist/
tesla-miniapp-frontend/unpackage/
tesla-miniapp-frontend/*.log
tesla-miniapp-frontend/.npm/

# Sensitive config - use .env.example as template
tesla-miniapp-frontend/.env
tesla-miniapp-frontend/.env.local
tesla-miniapp-frontend/.env.development
tesla-miniapp-frontend/.env.production
!tesla-miniapp-frontend/.env.example

