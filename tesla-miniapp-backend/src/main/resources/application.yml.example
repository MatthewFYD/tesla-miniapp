# =======================================================================
# Tesla MiniApp Backend Configuration
# Copy this file to application.yml and fill in your values
# =======================================================================

# Server Configuration
server:
  port: 8080
  servlet:
    context-path: /api
    encoding:
      charset: UTF-8
      enabled: true

# Spring Configuration
spring:
  application:
    name: tesla-miniapp-backend
  
  # Database Configuration - TeslaMate PostgreSQL
  datasource:
    url: jdbc:postgresql://YOUR_DB_HOST:5432/teslamate
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
    driver-class-name: org.postgresql.Driver
    hikari:
      maximum-pool-size: 20
      minimum-idle: 5
      idle-timeout: 300000
      connection-timeout: 20000
  
  # SQL initialization - create custom tables on startup
  sql:
    init:
      mode: always
      continue-on-error: true
      
  # JPA Configuration
  jpa:
    database-platform: org.hibernate.dialect.PostgreSQLDialect
    show-sql: false
    hibernate:
      ddl-auto: none  # Don't modify TeslaMate database
      naming:
        physical-strategy: org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
    properties:
      hibernate:
        format_sql: true
        use_sql_comments: true
    defer-datasource-initialization: true
        
  # JSON Configuration
  jackson:
    default-property-inclusion: non_null
    time-zone: Asia/Shanghai
    date-format: yyyy-MM-dd HH:mm:ss

# WeChat Configuration
wechat:
  miniapp:
    app-id: ${WECHAT_APP_ID:YOUR_WECHAT_APP_ID}
    app-secret: ${WECHAT_APP_SECRET:YOUR_WECHAT_APP_SECRET}
    session-timeout: 7200000  # 2 hours
    
# JWT Configuration
jwt:
  secret: ${JWT_SECRET:your-jwt-secret-key-change-this-in-production}
  expiration: 86400000  # 24 hours
  refresh-expiration: 604800000  # 7 days

# API Documentation
springdoc:
  api-docs:
    path: /docs/api-docs
  swagger-ui:
    path: /docs/swagger-ui.html
    operations-sorter: method

# Logging Configuration
logging:
  level:
    com.tesla.miniapp: INFO
    org.springframework.security: DEBUG
    org.hibernate.SQL: DEBUG
  pattern:
    console: '%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{50} - %msg%n'

# Management and Monitoring
management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics
  endpoint:
    health:
      show-details: when-authorized
